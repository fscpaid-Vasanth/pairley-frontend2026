rules_version = '2';

// Pairley Launch Pass — pre-launch campaign data.
// This project has no Cloud Functions backend, so these rules are the only
// server-side validation Launch Pass writes get. Every client is signed in
// anonymously (see ensureAnonymousAuth in src/firebase.js) before writing,
// which gives `request.auth.uid` a stable value to scope rules against.
//
// Known limitation: counters can still be incremented by any authenticated
// (including anonymous) client, so a determined bad actor could inflate the
// public "verified members" counter. Acceptable for a pre-launch vanity
// metric; harden with Cloud Functions if it becomes a real problem.
service cloud.firestore {
  match /databases/{database}/documents {

    // Aggregate campaign counters — publicly readable (shown on the public
    // dashboard/homepage to unauthenticated visitors), writable by any
    // signed-in (incl. anonymous) client since there's no server to
    // increment them instead.
    match /launchPassCounters/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // One doc per calendar day (id = YYYY-MM-DD) tracking that day's deltas
    // (registrations, businesses added) for the "daily return" experience.
    match /launchPassDaily/{dayId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // One membership doc per visitor, keyed by their Firebase uid.
    // Publicly readable (needed for the referral leaderboard query and for
    // a member's own pass to render); only the owning uid may write it.
    match /launchPassMembers/{memberId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == memberId;
      allow update: if request.auth != null && request.auth.uid == memberId;
      allow delete: if false;
    }

    // Merchant leads captured from the fast "/merchant/join" flow (mall
    // walk-ups, QR scans). Unlike launchPassMembers, these hold a real
    // mobile number — write-only from the client, not publicly readable
    // (view/follow-up happens via the Firebase Console Data tab, since
    // there's no server-side admin auth to scope a read rule against).
    match /launchPassMerchants/{leadId} {
      allow read: if false;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
